{
  "manifest_version": 3,
  "name": "PageScan",
  "description": "Extract styles from any website and generate DESIGN.md or SKILL.md content.",
  "version": "1.0.0",
  "action": {
    "default_title": "PageScan",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"]
}
